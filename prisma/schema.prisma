generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Legacy dashboard role on `User` before org-scoped `OrganizationMembership.role` (still used for coarse defaults).
enum UserLegacyRole {
  BOARD_MEMBER
  ADMIN
  GUEST
}

enum AgencyMemberRole {
  AGENCY_ADMIN
  AGENCY_STAFF
}

enum AgencyMemberStatus {
  ACTIVE
  INACTIVE
}

/// Mirrors `src/lib/organizations/membershipRole.ts` — stored per org membership.
enum OrganizationMembershipRole {
  PLATFORM_ADMIN
  OWNER
  ADMIN
  BOARD_CHAIR
  BOARD_MEMBER
  EXECUTIVE_DIRECTOR
  STAFF
  ATTORNEY_ADVISOR
  DEMO_USER
  VIEWER
}

enum OrganizationMembershipStatus {
  ACTIVE
  INACTIVE
}

/// App profile + tenancy; Supabase Auth owns credentials. Link `supabaseAuthId` to `auth.users.id` (RLS / organization_members).
model User {
  id               String         @id @default(cuid())
  name             String?
  email            String         @unique
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  supabaseAuthId   String?        @unique @db.Uuid
  /// Cross-tenant platform operator (legal / ops). Checked server-side for admin APIs.
  isPlatformAdmin  Boolean        @default(false)
  /// When false, server should refuse new memberships on `Organization.isDemoTenant` unless platform admin assigns.
  allowDemoOrganizationAssignment Boolean @default(false)
  /// Seeded demo personas (e.g. agency bench) — surfaced in UI via session, never hardcoded by email in components.
  isDemoUser       Boolean        @default(false)
  /// Legacy default; effective dashboard permissions come from `OrganizationMembership` for the active org.
  role             UserLegacyRole @default(BOARD_MEMBER)
  twoFactorEnabled Boolean        @default(false)
  twoFactorSecret  String?

  contentAccessLogs       ContentAccessLog[]
  organizationMemberships OrganizationMembership[]
  agencyMemberships       AgencyMember[]
  ownedAgencies           Agency[]                 @relation("AgencyOwner")
  profile                 UserProfile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([supabaseAuthId])
}

/// Global personal info and preferences (1:1 with app `User`). Not org-specific — use `OrganizationMembership.title` for board/staff titles per tenant.
model UserProfile {
  userId              String  @id
  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Preferred display name (mirrors product `full_name`; falls back to `User.name` in UI).
  fullName            String?
  jobTitle            String?
  phone               String?
  timezone            String?
  /// Public avatar URL (mirrors product `avatar_url`; falls back to `User.image`).
  avatarUrl           String?
  /// JSON string: notification prefs, meeting defaults — extend without migrations when possible.
  preferencesJson     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ContentAccessLog {
  id             String   @id @default(cuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  organizationId String?
  resourceType   String
  resourceKey    String
  href           String?
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
  @@index([organizationId, createdAt])
}

/// White-label reseller / law firm / MSP — owns many nonprofit `Organization` rows.
model Agency {
  id           String   @id @default(cuid())
  name         String
  ownerUserId  String
  owner        User     @relation("AgencyOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  isWhiteLabel Boolean  @default(false)
  /// Showcase / sandbox agency — auto-attaches configured demo bench users (`lib/demo/demo-agency-member.ts`).
  isDemoAgency Boolean @default(false)
  /// White-label / portal branding (optional overrides).
  brandingDisplayName  String?
  brandingLogoUrl      String?
  brandingPrimaryColor String?
  brandingSupportEmail String?
  brandingFooterText   String?
  organizations Organization[]
  members       AgencyMember[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([ownerUserId])
}

/// Agency-level team (GoHighLevel-style sub-account operators).
model AgencyMember {
  id        String   @id @default(cuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      AgencyMemberRole   @default(AGENCY_STAFF)
  status    AgencyMemberStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agencyId, userId])
  @@index([userId])
}

/// Tenant. Demo orgs: `isDemoTenant` + seeded data; `useSupabaseTenantData` reads Postgres via service role / RLS.
/// `billingPlan`: future — STARTER | GROWTH | ENTERPRISE
model Organization {
  id               String   @id @default(cuid())
  agencyId         String
  agency           Agency   @relation(fields: [agencyId], references: [id], onDelete: Restrict)
  name             String
  slug             String   @unique
  missionSnippet   String?
  logoUrl          String?
  primaryColor     String   @default("#6b5344")
  secondaryColor   String   @default("#5c7a7a")
  accentColor      String?
  /// When set, `getDashboardProfile(demoProfileKey)` loads mock board data (communityNonprofit, etc.)
  demoProfileKey   String?
  /// Legacy: when true without `useSupabaseTenantData`, UI uses bundled JSON profiles.
  demoModeEnabled  Boolean  @default(false)
  /// Sales / showcase tenant — show Demo badge, apply read-only guardrails unless `demoEditingEnabled`.
  isDemoTenant     Boolean  @default(false)
  /// Allow edits to seeded demo content (org admin / owner; still server-enforced).
  demoEditingEnabled Boolean @default(false)
  /// When true and Supabase tenant tables are populated, dashboard loads live tenant snapshot instead of mock JSON.
  useSupabaseTenantData Boolean @default(false)
  industryType     String?
  onboardingStatus String   @default("ACTIVE")
  billingPlan      String?
  /// Stripe Customer id (cus_…), set after first successful Checkout / Portal sync.
  stripeCustomerId     String?
  /// Active subscription id (sub_…); cleared when subscription ends.
  stripeSubscriptionId String?
  /// Optional free-text context for governance AI / standards tools (not shown publicly by default).
  governanceProfileNotes String?

  settings         OrganizationSettings?
  modules          OrganizationModule[]
  memberships      OrganizationMembership[]
  gcReviews        GcReviewRequest[]
  expertReviews    ExpertReviewRequest[]
  routingRules     IssueRoutingRule[]
  npAssessments    NpAssessment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId])
}

/// Global template: nonprofit organizational assessment (Authenticity Consulting / United Way style).
model NpAssessmentCategory {
  id           String                 @id @default(cuid())
  slug         String                 @unique
  name         String
  displayOrder Int
  questions    NpAssessmentQuestion[]

  createdAt DateTime @default(now())
}

model NpAssessmentQuestion {
  id            String   @id @default(cuid())
  categoryId    String
  category      NpAssessmentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  indicatorCode String                 @unique
  questionText  String
  /// E | R | A
  ratingType    String
  displayOrder  Int
  responses     NpAssessmentResponse[]

  @@index([categoryId, displayOrder])
}

/// One assessment run per org (multiple respondents via participants).
model NpAssessment {
  id                   String   @id @default(cuid())
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title                String   @default("Nonprofit organizational assessment")
  /// NOT_STARTED | IN_PROGRESS | COMPLETED | ARCHIVED (legacy: DRAFT→NOT_STARTED, SUBMITTED→COMPLETED)
  status               String   @default("NOT_STARTED")
  allowAnonymous       Boolean  @default(false)
  /// When false, board members may not save responses (chairs/admins/staff still can).
  allowBoardMemberFill Boolean  @default(true)
  currentCategoryIndex Int      @default(0)
  createdByUserId      String?
  submittedAt          DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  participants NpAssessmentParticipant[]
  responses    NpAssessmentResponse[]
  reports      NpAssessmentReport[]

  @@index([organizationId, updatedAt])
  @@index([organizationId, status])
}

model NpAssessmentParticipant {
  id            String   @id @default(cuid())
  assessmentId  String
  assessment    NpAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  label         String?
  userId        String?
  /// When set, client can resume without tying to a user (paired with allowAnonymous on assessment).
  resumeToken   String?  @unique
  isAnonymous   Boolean  @default(false)
  createdAt     DateTime @default(now())

  responses NpAssessmentResponse[]

  @@index([assessmentId])
  @@unique([assessmentId, userId])
}

model NpAssessmentResponse {
  id            String   @id @default(cuid())
  assessmentId  String
  assessment    NpAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  participantId String
  participant   NpAssessmentParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  questionId    String
  question      NpAssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  /// MET | NEEDS_WORK | NA | DONT_KNOW
  answer        String
  notes         String?
  /// Derived: true when answer !== MET (consult path).
  flaggedForConsult Boolean @default(false)
  completedByUserId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([participantId, questionId])
  @@index([assessmentId])
}

/// Optional cached report snapshot (aggregate or per participant).
model NpAssessmentReport {
  id            String   @id @default(cuid())
  assessmentId  String
  assessment    NpAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  participantId String?
  payload       String
  generatedAt   DateTime @default(now())

  @@index([assessmentId])
}

/// Extended org config (theme, domain, landing). Branding colors live on `Organization` for simpler queries.
model OrganizationSettings {
  id                 String   @id @default(cuid())
  organizationId     String   @unique
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  themeMode          String   @default("light")
  faviconUrl         String?
  customDomain       String?
  defaultLandingPage String   @default("/overview")
  /// JSON string (SQLite): board structure, committees, prefs — see `lib/organization-settings/extended-settings.ts`.
  extendedSettings   String?
  updatedAt          DateTime @updatedAt
}

model OrganizationModule {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  moduleName     String
  isEnabled      Boolean      @default(true)

  @@unique([organizationId, moduleName])
}

model OrganizationMembership {
  id             String                   @id @default(cuid())
  organizationId String
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// System permission in this org. Use `membershipRoleDisplayLabel` for UI.
  role   OrganizationMembershipRole   @default(VIEWER)
  /// Real-world position in this org only (e.g. Board Chair, Treasurer). Not used for authorization.
  title  String?
  /// Inactive members must not access org APIs or Supabase tenant RLS.
  status OrganizationMembershipStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, userId])
  @@index([userId, status])
}

model GcReviewRequest {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  itemType  String
  itemId    String
  itemTitle String

  reason           String
  summaryConcern   String
  urgency          String
  relatedDeadline  DateTime?
  supportingNotes  String?

  flaggedByUserId String?
  flaggedByEmail  String?
  flaggedByName   String?
  flaggedAt       DateTime @default(now())

  status String @default("PENDING")

  reviewNotes       String?
  recommendation    String?
  nextStep          String?
  reviewCompletedAt DateTime?
  reviewedByUserId  String?

  updatedAt DateTime @updatedAt

  @@unique([organizationId, itemType, itemId])
  @@index([organizationId, status])
  @@index([organizationId, urgency])
}

/// Per-organization routing destinations for expert review categories.
model IssueRoutingRule {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category         String
  displayName      String
  destinationEmail String       @default("")
  isActive         Boolean      @default(true)
  fallbackEmail    String?
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([organizationId, category])
}

model ExpertReviewRequest {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  category         String
  subject          String
  summary          String
  priority         String
  deadline         DateTime?
  additionalNotes  String?

  createdByUserId String?
  createdByEmail  String?
  createdByName   String?
  createdAt       DateTime @default(now())

  relatedItemType  String
  relatedItemId    String
  relatedItemTitle String?
  relatedHref      String?

  organizationName String?
  destinationEmail   String
  status             String    @default("SUBMITTED")
  emailSentAt        DateTime?
  lastError          String?

  updatedAt DateTime @updatedAt

  @@index([organizationId, createdAt])
  @@index([organizationId, relatedItemType, relatedItemId])
  @@index([createdByUserId])
}
