generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String  @id @default(cuid())
  name             String?
  email            String  @unique
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  /// Supabase Auth user id — used for Postgres RLS `auth.uid()` sync (`organization_members`).
  supabaseAuthId   String? @unique
  /// Cross-tenant platform operator (legal / ops). Checked server-side for admin APIs.
  isPlatformAdmin  Boolean @default(false)
  /// When false, server should refuse new memberships on `Organization.isDemoTenant` unless platform admin assigns.
  allowDemoOrganizationAssignment Boolean @default(false)
  /// Legacy default; effective dashboard permissions come from `OrganizationMembership` for the active org.
  role             String  @default("BOARD_MEMBER")
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?

  accounts            Account[]
  sessions            Session[]
  contentAccessLogs   ContentAccessLog[]
  organizationMemberships OrganizationMembership[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ContentAccessLog {
  id             String   @id @default(cuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  organizationId String?
  resourceType   String
  resourceKey    String
  href           String?
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
  @@index([organizationId, createdAt])
}

/// Tenant. Demo orgs: `isDemoTenant` + seeded data; `useSupabaseTenantData` reads Postgres via service role / RLS.
/// `billingPlan`: future — STARTER | GROWTH | ENTERPRISE
model Organization {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  missionSnippet   String?
  logoUrl          String?
  primaryColor     String   @default("#6b5344")
  secondaryColor   String   @default("#5c7a7a")
  accentColor      String?
  /// When set, `getDashboardProfile(demoProfileKey)` loads mock board data (communityNonprofit, etc.)
  demoProfileKey   String?
  /// Legacy: when true without `useSupabaseTenantData`, UI uses bundled JSON profiles.
  demoModeEnabled  Boolean  @default(false)
  /// Sales / showcase tenant — show Demo badge, apply read-only guardrails unless `demoEditingEnabled`.
  isDemoTenant     Boolean  @default(false)
  /// Allow edits to seeded demo content (org admin / owner; still server-enforced).
  demoEditingEnabled Boolean @default(false)
  /// When true and Supabase tenant tables are populated, dashboard loads live tenant snapshot instead of mock JSON.
  useSupabaseTenantData Boolean @default(false)
  industryType     String?
  onboardingStatus String   @default("ACTIVE")
  billingPlan      String?
  /// Optional free-text context for governance AI / standards tools (not shown publicly by default).
  governanceProfileNotes String?

  settings         OrganizationSettings?
  modules          OrganizationModule[]
  memberships      OrganizationMembership[]
  gcReviews        GcReviewRequest[]
  expertReviews    ExpertReviewRequest[]
  routingRules     IssueRoutingRule[]
  npAssessments    NpAssessment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Global template: nonprofit organizational assessment (Authenticity Consulting / United Way style).
model NpAssessmentCategory {
  id           String                 @id @default(cuid())
  slug         String                 @unique
  name         String
  displayOrder Int
  questions    NpAssessmentQuestion[]

  createdAt DateTime @default(now())
}

model NpAssessmentQuestion {
  id            String   @id @default(cuid())
  categoryId    String
  category      NpAssessmentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  indicatorCode String                 @unique
  questionText  String
  /// E | R | A
  ratingType    String
  displayOrder  Int
  responses     NpAssessmentResponse[]

  @@index([categoryId, displayOrder])
}

/// One assessment run per org (multiple respondents via participants).
model NpAssessment {
  id                   String   @id @default(cuid())
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title                String   @default("Nonprofit organizational assessment")
  /// DRAFT | IN_PROGRESS | SUBMITTED
  status               String   @default("DRAFT")
  allowAnonymous       Boolean  @default(false)
  currentCategoryIndex Int      @default(0)
  createdByUserId      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  participants NpAssessmentParticipant[]
  responses    NpAssessmentResponse[]
  reports      NpAssessmentReport[]

  @@index([organizationId, updatedAt])
}

model NpAssessmentParticipant {
  id            String   @id @default(cuid())
  assessmentId  String
  assessment    NpAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  label         String?
  userId        String?
  /// When set, client can resume without tying to a user (paired with allowAnonymous on assessment).
  resumeToken   String?  @unique
  isAnonymous   Boolean  @default(false)
  createdAt     DateTime @default(now())

  responses NpAssessmentResponse[]

  @@index([assessmentId])
}

model NpAssessmentResponse {
  id            String   @id @default(cuid())
  assessmentId  String
  assessment    NpAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  participantId String
  participant   NpAssessmentParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  questionId    String
  question      NpAssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  /// MET | NEEDS_WORK | NA | DONT_KNOW
  answer        String
  updatedAt     DateTime @updatedAt

  @@unique([participantId, questionId])
  @@index([assessmentId])
}

/// Optional cached report snapshot (aggregate or per participant).
model NpAssessmentReport {
  id            String   @id @default(cuid())
  assessmentId  String
  assessment    NpAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  participantId String?
  payload       String
  generatedAt   DateTime @default(now())

  @@index([assessmentId])
}

/// Extended org config (theme, domain, landing). Branding colors live on `Organization` for simpler queries.
model OrganizationSettings {
  id                 String   @id @default(cuid())
  organizationId     String   @unique
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  themeMode          String   @default("light")
  faviconUrl         String?
  customDomain       String?
  defaultLandingPage String   @default("/overview")
  /// JSON string (SQLite): board structure, committees, prefs — see `lib/organization-settings/extended-settings.ts`.
  extendedSettings   String?
  updatedAt          DateTime @updatedAt
}

model OrganizationModule {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  moduleName     String
  isEnabled      Boolean      @default(true)

  @@unique([organizationId, moduleName])
}

model OrganizationMembership {
  id             String                   @id @default(cuid())
  organizationId String
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// OWNER | ADMIN | BOARD_CHAIR | BOARD_MEMBER | STAFF | VIEWER (SQLite: store as string)
  role String @default("VIEWER")

  createdAt DateTime @default(now())

  @@unique([organizationId, userId])
}

model GcReviewRequest {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  itemType  String
  itemId    String
  itemTitle String

  reason           String
  summaryConcern   String
  urgency          String
  relatedDeadline  DateTime?
  supportingNotes  String?

  flaggedByUserId String?
  flaggedByEmail  String?
  flaggedByName   String?
  flaggedAt       DateTime @default(now())

  status String @default("PENDING")

  reviewNotes       String?
  recommendation    String?
  nextStep          String?
  reviewCompletedAt DateTime?
  reviewedByUserId  String?

  updatedAt DateTime @updatedAt

  @@unique([organizationId, itemType, itemId])
  @@index([organizationId, status])
  @@index([organizationId, urgency])
}

/// Per-organization routing destinations for expert review categories.
model IssueRoutingRule {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category         String
  displayName      String
  destinationEmail String       @default("")
  isActive         Boolean      @default(true)
  fallbackEmail    String?
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([organizationId, category])
}

model ExpertReviewRequest {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  category         String
  subject          String
  summary          String
  priority         String
  deadline         DateTime?
  additionalNotes  String?

  createdByUserId String?
  createdByEmail  String?
  createdByName   String?
  createdAt       DateTime @default(now())

  relatedItemType  String
  relatedItemId    String
  relatedItemTitle String?
  relatedHref      String?

  organizationName String?
  destinationEmail   String
  status             String    @default("SUBMITTED")
  emailSentAt        DateTime?
  lastError          String?

  updatedAt DateTime @updatedAt

  @@index([organizationId, createdAt])
  @@index([organizationId, relatedItemType, relatedItemId])
  @@index([createdByUserId])
}
