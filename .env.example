# Copy to .env — never commit real secrets
# Vercel: set AUTH_SECRET on Production and Preview (e.g. openssl rand -base64 32).
# Use a hosted DATABASE_URL (Postgres); file: SQLite is for local dev only.
DATABASE_URL="file:./dev.db"
AUTH_SECRET=
# Production: https://your-domain.com (or preview URL). Vercel: set explicitly for custom domains;
# if unset, forgot-password links fall back to https://VERCEL_URL.
AUTH_URL=http://localhost:3000

# Optional: Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional: Microsoft Entra ID (SSO)
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=

# --- Supabase (Vercel: add under Project → Settings → Environment Variables) ---
# Client-safe (embedded in browser bundle). Use the "anon" / "public" key from Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Legacy alias still supported if ANON_KEY is unset:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Supabase Dashboard → Authentication → URL configuration:
# - Site URL: https://your-production-domain.com (and/or https://*.vercel.app for previews); local dev often http://localhost:3000
# - Redirect URLs: add https://your-production-domain.com/** and https://YOUR_PROJECT.vercel.app/**
#   Also add http://localhost:3000/auth/callback and https://YOUR_DOMAIN/auth/callback — signInWithOtp uses emailRedirectTo there.
# Email OTP: Authentication → Providers → Email enabled. Sign-in / magic-link template must show the code: include {{ .Token }}.
#   If using custom SMTP, check Authentication → Logs for delivery failures.
# LinkedIn (OIDC): Authentication → Providers → LinkedIn (OIDC). Add to Supabase Redirect URLs:
#   https://YOUR_DOMAIN/auth/callback
#   http://localhost:3000/auth/callback
# LinkedIn app Authorized redirect URL remains your Supabase callback:
#   https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback

# Server-only — NEVER prefix with NEXT_PUBLIC_. Optional: demo todos API / health checks. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=
# When running `npm run db:seed`, set to 1 with service role + applied supabase/migrations to seed Community Outreach into Postgres and enable useSupabaseTenantData for that org.
# SEED_SUPABASE_TENANT=1

# --- Optional demo table (SQL Editor in Supabase) ---
# create table if not exists public.todos (
#   id uuid primary key default gen_random_uuid(),
#   name text not null,
#   created_at timestamptz default now()
# );
# alter table public.todos enable row level security;
# -- Example permissive policy for anon read (tighten for production):
# create policy "todos_select_all" on public.todos for select using (true);
# -- Writes from this app use the service role in /api/supabase/todos after NextAuth.

# Server-only — never expose to client
OPENAI_API_KEY=

# --- Stripe (billing) — server-only except publishable key ---
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Webhook signing secret: Developers → Webhooks → endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=
# Recurring Price id (price_…) for Checkout — in Stripe, create USD $299.99 / month
# (or match whatever you set in src/lib/stripe/plan-display.ts) and paste the id here.
STRIPE_PRICE_ID=
# Client-safe publishable key (pk_test_… / pk_live_…) for Stripe.js / Payment Element
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
