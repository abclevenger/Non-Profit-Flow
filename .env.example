# Copy to .env — never commit real secrets
# Prisma: Supabase Postgres (copy URI mode strings from Supabase → Project Settings → Database).
# Pooler URL → DATABASE_URL (Transaction pooler, port 6543). Direct URL → DIRECT_URL (port 5432, migrations/db push).
# Use sslmode=require for TLS. Pooler username is often postgres.<project-ref> — match the dashboard string exactly.
#
# If `prisma db push` fails with P1001 on DIRECT_URL (can't reach db.<ref>.supabase.co:5432):
# - Unpause the project; check Database → Network restrictions / IPv4 (some networks need Supabase IPv4 add-on).
# - Try another network or disable VPN; confirm corporate firewall allows outbound 5432.
# - Re-copy the "Direct connection" string from the dashboard (host/region can differ from examples).
DATABASE_URL="postgresql://postgres:YOUR_SUPABASE_DB_PASSWORD@<POOLER_HOST>:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
DIRECT_URL="postgresql://postgres:YOUR_SUPABASE_DB_PASSWORD@<DIRECT_HOST>:5432/postgres?sslmode=require"

# --- Vercel (or any hosted deploy) — serverless needs these at runtime ---
# Project → Settings → Environment Variables: add DATABASE_URL and DIRECT_URL for Production
# *and* Preview (Preview does not inherit Production; missing vars → "DATABASE_URL is not set" on /login).
# Also set NEXT_PUBLIC_SUPABASE_* (and SUPABASE_SERVICE_ROLE_KEY if you use service-role APIs).
# After saving env: Redeploy. Local: put the same keys in `.env` or `.env.local` next to package.json and restart `npm run dev`.
# Note: DISABLE_APP_AUTH is ignored when NODE_ENV=production (e.g. Vercel); the database URLs are still required.

# --- INSECURE local-only auth bypass (remove before any shared or production deploy) ---
# When true and NODE_ENV is not production: skip Supabase login in `src/proxy.ts` and treat every
# request as the Prisma user below with full platform-admin workspace (no password, no OTP).
# Prisma still connects to Postgres — DATABASE_URL / DIRECT_URL above are still required locally.
# Default email matches `npm run db:seed` board admin. Unset or set to 0 to restore normal auth.
# DISABLE_APP_AUTH=true
# DEV_BYPASS_USER_EMAIL=admin@board.demo

# Seeded Prisma password sign-in (POST /api/auth/seeded-password-login) — off in production unless:
# ALLOW_SEEDED_PASSWORD_LOGIN=true
# Optional: show the “Seeded account (password)” block on /login in production builds:
# NEXT_PUBLIC_SHOW_SEEDED_PASSWORD_LOGIN=1

# Absolute links (e.g. password reset URL in forgot-password dev response). Vercel: set for custom domains;
# if unset, falls back to https://VERCEL_URL then localhost.
AUTH_URL=http://localhost:3000
# Legacy alias (optional):
# NEXTAUTH_URL=

# --- Supabase (Vercel: add under Project → Settings → Environment Variables) ---
# Client-safe (embedded in browser bundle). Use the "anon" / "public" key from Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Legacy alias still supported if ANON_KEY is unset:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Supabase Dashboard → Authentication → URL configuration:
# - Site URL: https://your-production-domain.com (and/or https://*.vercel.app for previews); local dev often http://localhost:3000
# - Redirect URLs: add https://your-production-domain.com/** and https://YOUR_PROJECT.vercel.app/**
#   Also add every origin you use in dev (signInWithOtp / OAuth use window.location.origin + /auth/callback), e.g.:
#   http://localhost:3000/auth/callback
#   http://localhost:3001/auth/callback
#   http://localhost:301/auth/callback
#   http://127.0.0.1:3000/auth/callback
#   http://10.20.24.60:3001/auth/callback   (LAN IP — replace with yours)
#   https://YOUR_DOMAIN/auth/callback
# Long-lived sessions: browser cookies use a 30-day max age (see src/lib/supabase/session-cookie-options.ts).
# Supabase Dashboard → Authentication → set JWT expiry / refresh behavior to match your security policy.
# Email OTP: Authentication → Providers → Email enabled. Sign-in / magic-link template must show the code: include {{ .Token }}.
#   If using custom SMTP, check Authentication → Logs for delivery failures.
# LinkedIn (OIDC): Authentication → Providers → LinkedIn (OIDC). Add to Supabase Redirect URLs:
#   https://YOUR_DOMAIN/auth/callback
#   http://localhost:3000/auth/callback
# LinkedIn app Authorized redirect URL remains your Supabase callback:
#   https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback

# Server-only — NEVER prefix with NEXT_PUBLIC_. Optional: demo todos API / health checks. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=
# Dev-only: passwordless sign-in on /login (POST /api/auth/dev-login). Requires SERVICE_ROLE_KEY.
# Never set on production. When unset, bypass is still allowed locally via NODE_ENV=development.
# ENABLE_DEV_LOGIN_BYPASS=true
# Dev login API currently allows only ashley@ymbs.pro (see src/lib/auth/dev-login-bypass.ts).

# When running `npm run db:seed`, set to 1 with service role + applied supabase/migrations to seed Community Outreach into Postgres and enable useSupabaseTenantData for that org.
# SEED_SUPABASE_TENANT=1

# --- Optional demo table (SQL Editor in Supabase) ---
# create table if not exists public.todos (
#   id uuid primary key default gen_random_uuid(),
#   name text not null,
#   created_at timestamptz default now()
# );
# alter table public.todos enable row level security;
# -- Example permissive policy for anon read (tighten for production):
# create policy "todos_select_all" on public.todos for select using (true);
# -- Writes from this app use the service role in /api/supabase/todos.

# Server-only — never expose to client
OPENAI_API_KEY=

# --- Stripe (billing) — server-only except publishable key ---
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Webhook signing secret: Developers → Webhooks → endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=
# Recurring Price id (price_…) for Checkout — in Stripe, create USD $299.99 / month
# (or match whatever you set in src/lib/stripe/plan-display.ts) and paste the id here.
STRIPE_PRICE_ID=
# Client-safe publishable key (pk_test_… / pk_live_…) for Stripe.js / Payment Element
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
